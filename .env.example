# ─── Clerk (auth) — already configured ────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Supabase (database + storage) — Phase 0 ──────────────────────────────────
# Project Settings → API Keys. The secret key is SERVER-ONLY — never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ─── AI image provider (Phase 1) — provider chosen later ──────────────────────
# ANTHROPIC_API_KEY is used for title/CTR copy; add the image provider key here.
# ANTHROPIC_API_KEY=sk-ant-...
# REPLICATE_API_TOKEN=r8_...

# ─── Stripe (Phase 3) ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
